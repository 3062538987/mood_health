{
  "name": "mood-health-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "start-all": "powershell -ExecutionPolicy Bypass -File start-project.ps1",
    "start-all:check": "powershell -ExecutionPolicy Bypass -File start-all-with-check.ps1",
    "start-all:concurrent": "npx concurrently \"npm --prefix . run dev\" \"npm --prefix mood-health-server run dev\" \"python -m uvicorn mood-health-server.main:app --host 0.0.0.0 --port 8000\""
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.6.8",
    "echarts": "^5.4.3",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "^2.13.3",
    "pinia": "^2.3.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/ui": "^2.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^14.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.94.2",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.6"
  }
}
