# Node runtime
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
FRONTEND_URL=https://your-domain.com

# Security
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace_with_64_hex_chars

# Database (2C2G recommended)
DB_CLIENT=sqlite
SQLITE_DB_PATH=/var/www/mood-health/mood-health-server/data/mood-health.db

# AI strategy (no local model)
AI_ENABLED=false
AI_SERVICE_BASE_URL=http://127.0.0.1:8000

# Optional cache
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=

# Login rate limit
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=20

# Generic rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
