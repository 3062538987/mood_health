{
  "name": "mood-health-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:init:sqlite": "ts-node src/scripts/initSqliteDb.ts",
    "seed:demo": "ts-node src/scripts/seedDemoData.ts",
    "seed:demo:all": "npm run seed:demo -- 123456 && npm run verify:demo-users -- 123456",
    "verify:demo-users": "ts-node src/scripts/verifyDemoUsers.ts",
    "set:role": "ts-node src/scripts/setRole.ts",
    "test:sqlite-smoke": "ts-node src/scripts/sqliteSmokeTest.ts",
    "test:role-permissions": "ts-node src/scripts/test_role_permissions.ts",
    "doctor": "node -e \"require('fs').existsSync('dist/app.js') ? (console.log('dist/app.js found'), process.exit(0)) : (console.log('dist/app.js missing, run npm run build'), process.exit(1))\"",
    "test": "npm run test:stable",
    "test:stable": "jest tests/utils/ai/counselingService.test.ts",
    "test:integration": "jest tests/unit --runInBand",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mssql": "^12.2.0",
    "node-fetch": "^2.7.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.3.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
