{
  "python.terminal.useEnvFile": true,
  "python.terminal.activateEnvironment": false,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.envFile": "${workspaceFolder}/mood-health-server/.env",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.env.windows": {
    "PYTHONUTF8": "1"
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/dist/**": true,
    "**/logs/**": true,
    "**/redis/**": true,
    "**/__pycache__/**": true,
    "**/mood-health-server/deepseek-chat-1.5b/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/venv": true,
    "**/dist": true,
    "**/logs": true,
    "**/redis": true,
    "**/__pycache__": true,
    "**/mood-health-server/deepseek-chat-1.5b": true
  }
}
