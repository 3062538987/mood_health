# 后端环境变量示例
# 复制此文件为 .env 并填写实际值

# Node.js 环境
NODE_ENV=development
PORT=3000

# 数据库驱动选择（sqlserver / sqlite）
# 低配部署建议默认使用 sqlite
DB_CLIENT=sqlite
# 建议在测试/部署中使用绝对路径，避免工作目录变化导致指向错误文件
SQLITE_DB_PATH=D:/deploy/mood-health/data/mood-health.db

# SQL Server 配置
DB_SERVER=localhost
DB_PORT=1433
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=mood_health
# 使用 Windows 身份验证（true/false）
USE_WINDOWS_AUTH=false

# JWT 配置
# 开发环境和生产环境必须使用不同的强随机值
# 生成命令（OpenSSL）: openssl rand -base64 32
# 生成命令（Node.js）: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# 加密密钥（32字节，hex编码）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_encryption_key_hex_encoded_here_64chars

# 前端 URL（用于 CORS，多个域名用逗号分隔）
FRONTEND_URL=http://localhost:3001,http://localhost:5173

# AI 开关（2核2G 低配部署建议 false）
AI_ENABLED=false
# 当 AI_ENABLED=true 时可转发到独立 AI 服务
AI_SERVICE_BASE_URL=http://127.0.0.1:8000

# Redis 配置（用于 AI 服务缓存）
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
# doctor 是否强制 Redis 连通检查（2核2G 无 AI 可设为 false）
REDIS_REQUIRED=false

# Ollama 配置（AI 服务）
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=deepseek-r1:1.5b

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# 登录限流（生产可按实际流量调整）
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=20

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs
